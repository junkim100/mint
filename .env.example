# ============================================================================
# MINT Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your credentials:
#   cp .env.example .env
#   # Edit .env and add your HF_TOKEN
#
# All parameters below are OPTIONAL except HF_TOKEN.
# Uncomment and modify values to override defaults.
# ============================================================================

# ============================================================================
# REQUIRED: HuggingFace Token
# ============================================================================
# Get your token from: https://huggingface.co/settings/tokens
# You must also request access to: https://huggingface.co/meta-llama/Llama-3.1-8B-Instruct
HF_TOKEN=hf_your_token_here

# ============================================================================
# OPTIONAL: OpenAI API Key
# ============================================================================
# Required only for certain evaluation tasks
# Get your key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your_key_here

# ============================================================================
# Pipeline Configuration (Optional - defaults shown)
# ============================================================================
# These parameters control the scale of the pipeline.
# Default values are configured for standard experiments.
# Adjust based on your computational resources and requirements.

# Number of samples for MFB construction (affordance discovery)
# Default: 10000
# NUM_SAMPLES=10000

# Number of counterfactual pairs to collect for training
# Default: 1000
# NUM_PAIRS=1000

# Training steps for editors and value heads
# Default: 3000
# TRAIN_STEPS=3000

# Batch size for training and inference
# Default: 32 (adjust based on GPU memory)
# BATCH_SIZE=32

# Number of evaluation samples
# Default: 100
# EVAL_SAMPLES=100

# ============================================================================
# Hardware Configuration (Optional)
# ============================================================================

# CUDA device IDs (comma-separated list of GPU IDs to use)
# Default: 0,1,2,3,4,5,6,7 (all 8 GPUs)
# Examples:
#   CUDA_VISIBLE_DEVICES=0,1,2,3      # Use first 4 GPUs
#   CUDA_VISIBLE_DEVICES=0            # Use only GPU 0
#   CUDA_VISIBLE_DEVICES=             # Use CPU only (very slow)
# CUDA_VISIBLE_DEVICES=0,1,2,3,4,5,6,7

# Disable tokenizer parallelism warnings (recommended)
# Default: false
# TOKENIZERS_PARALLELISM=false

# ============================================================================
# Model Configuration (Advanced - rarely need to change)
# ============================================================================

# Model name from HuggingFace
# Default: meta-llama/Llama-3.1-8B-Instruct
# MODEL_NAME=meta-llama/Llama-3.1-8B-Instruct

# Tensor parallelism size (number of GPUs for model parallelism)
# Default: 8 (matches CUDA_VISIBLE_DEVICES default)
# TENSOR_PARALLEL_SIZE=8

# Maximum sequence length for model
# Default: 2048
# MAX_MODEL_LEN=2048

# ============================================================================
# Debugging and Development (Optional)
# ============================================================================

# Logging level
# Default: INFO
# Options: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# Random seed for reproducibility
# Default: 42
# SEED=42

# ============================================================================
# Quick Start Examples
# ============================================================================
#
# Example 1: Standard pipeline (default configuration)
#   cp .env.example .env
#   # Add HF_TOKEN
#   docker exec mint_container ./run.sh
#   # Runtime: ~4-6 hours on 8× A100 80GB
#
# Example 2: Reduced scale (faster, less accurate)
#   cp .env.example .env
#   # Add HF_TOKEN and uncomment these lines:
#   NUM_SAMPLES=1000
#   NUM_PAIRS=100
#   TRAIN_STEPS=500
#   BATCH_SIZE=16
#   EVAL_SAMPLES=20
#   # Runtime: ~30-45 minutes
#
# Example 3: Use only 4 GPUs
#   cp .env.example .env
#   # Add HF_TOKEN and uncomment:
#   CUDA_VISIBLE_DEVICES=0,1,2,3
#   TENSOR_PARALLEL_SIZE=4
#
# ============================================================================

